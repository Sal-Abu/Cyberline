---
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { cn } from '@/lib/cn';
import { t, getLocaleFromPath } from '@/i18n';

interface Props {
  action?: string;
  successMessage?: string;
  class?: string;
}

const locale = getLocaleFromPath(Astro.url.pathname);

const {
  action = '/api/contact',
  successMessage = t('contact.success', locale),
  class: className,
} = Astro.props;
---

<form
  id="contact-form"
  action={action}
  method="POST"
  class={cn('space-y-6', className)}
  data-success-message={successMessage}
  data-sending={t('contact.sending', locale)}
  data-generic-error={t('contact.genericError', locale)}
  data-error-message={t('contact.error', locale)}
>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <Input
      label={t('contact.name', locale)}
      name="name"
      type="text"
      required
      autocomplete="name"
    />
    <Input
      label={t('contact.email', locale)}
      name="email"
      type="email"
      required
      autocomplete="email"
    />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <Input
      label="Company Name (Optional)"
      name="company"
      type="text"
      autocomplete="organization"
    />
    <Input
      label="Phone Number (Optional)"
      name="phone"
      type="tel"
      autocomplete="tel"
    />
  </div>

  <div class="space-y-2">
    <label for="subject" class="text-sm font-medium text-foreground">
      {t('contact.subject', locale) || 'What can we help you with?'}
    </label>
    <select
      id="subject"
      name="subject"
      class="w-full rounded-md border border-border bg-background px-3 py-2.5 text-sm text-foreground focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500 transition-colors"
    >
      <option value="General Inquiry">General Inquiry</option>
      <option value="Web Development">Web Development & Management</option>
      <option value="IT Consulting and Support">IT Support & Consulting</option>
      <option value="Business Automations">Business Automations</option>
      <option value="AI Tooling">AI Tooling for Business</option>
      <option value="Support">Existing Client Support</option>
    </select>
  </div>

  <Textarea
    label={t('contact.message', locale)}
    name="message"
    required
    rows={5}
  />

  <div class="hidden" aria-hidden="true">
    <input type="text" name="honeypot" tabindex="-1" autocomplete="off" />
  </div>

  <div id="form-message" class="hidden text-sm"></div>

  <div class="flex justify-center">
    <Button type="submit" id="submit-button" class="gap-2 cta-btn-brand">
      {t('contact.send', locale)}
      <Icon name="arrow-right" size="sm" />
    </Button>
  </div>
</form>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const button = document.getElementById('submit-button') as HTMLButtonElement;
    const message = document.getElementById('form-message') as HTMLDivElement;

    if (!form || !button || !message) return;

    // --- Subject URL Parameter Auto-Fill Logic ---
    const params = new URLSearchParams(window.location.search);
    const prefillSubject = params.get('subject');
    const subjectSelect = document.getElementById('subject') as HTMLSelectElement;

    if (prefillSubject && subjectSelect) {
      subjectSelect.value = prefillSubject;
      
      // Highlight briefly so the user sees it updated
      subjectSelect.style.transition = 'background-color 0.3s ease';
      subjectSelect.style.backgroundColor = 'rgba(var(--brand-500), 0.1)'; 
      
      setTimeout(() => {
        subjectSelect.style.backgroundColor = '';
      }, 1500);
    }
    // ---------------------------------------------

    const successMessage = form.dataset.successMessage || 'Message sent successfully!';
    const originalButtonHTML = button.innerHTML;

    // Remove old listeners to prevent duplicates during view transitions
    const newForm = form.cloneNode(true) as HTMLFormElement;
    form.parentNode?.replaceChild(newForm, form);
    
    // Re-select elements after cloning
    const newButton = document.getElementById('submit-button') as HTMLButtonElement;
    const newMessage = document.getElementById('form-message') as HTMLDivElement;

    newForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      newButton.disabled = true;
      newButton.textContent = newForm.dataset.sending || 'Sending…';
      newMessage.classList.add('hidden');

      try {
        const formData = new FormData(newForm);
        const response = await fetch(newForm.action, {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.success) {
          newMessage.textContent = successMessage;
          newMessage.className = 'text-sm text-success';
          newForm.reset();
          
          // Reset the subject to the prefilled option if it exists after successful submission
          if (prefillSubject && subjectSelect) {
             const updatedSelect = document.getElementById('subject') as HTMLSelectElement;
             if (updatedSelect) updatedSelect.value = prefillSubject;
          }
        } else {
          const errors = data.errors
            ? Object.values(data.errors).flat().join(', ')
            : (newForm.dataset.genericError || 'Something went wrong');
          newMessage.textContent = errors as string;
          newMessage.className = 'text-sm text-destructive';
        }
      } catch {
        newMessage.textContent = newForm.dataset.errorMessage || 'Failed to send message. Please try again.';
        newMessage.className = 'text-sm text-destructive';
      } finally {
        newButton.disabled = false;
        newButton.innerHTML = originalButtonHTML;
        newMessage.classList.remove('hidden');
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
